# Database configuration (แบบแยกชิ้นสำหรับเรียกใช้ในแอป)
DB_USER="user"
DB_PASSWORD="password"
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="db_name"
DB_SCHEMA="public"

# Prisma CLI จำเป็นต้องใช้แบบ String ต่อกัน (ตัวแปรนี้มีไว้สำหรับ npx prisma db push, migrate ฯลฯ)
DATABASE_URL="postgresql://user:password@localhost:5432/db_name?schema=public"

# App configuration
NODE_ENV="development"
PORT=3000
LOG_LEVEL="info"
CORS_ORIGINS="http://localhost:3000"

# Authentication
JWT_SECRET="your_jwt_secret_here"
JWT_EXPIRES_IN="60m"

# Redis caching and queue
REDIS_HOST="localhost"
REDIS_PORT=6379

# External APIs
EXTERNAL_INSPIRATION_API_URL="https://httpstat.us/500"

# Circuit Breaker Configuration
CB_TIMEOUT_MS=3000
CB_ERROR_THRESHOLD=50
CB_RESET_TIMEOUT_MS=5000